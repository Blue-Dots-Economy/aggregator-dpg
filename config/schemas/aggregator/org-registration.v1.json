{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.bluedots.org/aggregator/org-registration.v1.json",
  "title": "Organisation Registration",
  "description": "Signup payload for a new parent organisation (spec §6.1). Captures the org display name, optional state, the org owner's contact identity, and consent. The URL slug is generated by the server at submit and is not supplied by the client. Coordinators register separately and select an approved org.",
  "type": "object",
  "additionalProperties": false,
  "required": ["display_name", "owner", "consent"],
  "properties": {
    "display_name": {
      "type": "string",
      "title": "Organisation Name",
      "minLength": 2,
      "maxLength": 200,
      "examples": ["Enable India", "Pankh Foundation"]
    },
    "state": {
      "type": "string",
      "title": "State",
      "maxLength": 200,
      "examples": ["Karnataka", "Maharashtra"]
    },
    "owner": {
      "type": "object",
      "title": "Organisation Owner",
      "additionalProperties": false,
      "required": ["name", "phone", "email"],
      "properties": {
        "name": {
          "type": "string",
          "title": "Owner Name",
          "minLength": 2,
          "maxLength": 200,
          "examples": ["Rajesh Kumar"]
        },
        "phone": {
          "type": "string",
          "title": "Phone",
          "pattern": "^(\\+?\\d{10,15}|\\d{10})$",
          "examples": ["+919876543210", "9876543210"]
        },
        "email": {
          "type": "string",
          "title": "Email",
          "format": "email",
          "maxLength": 320,
          "examples": ["owner@enableindia.org"]
        }
      }
    },
    "consent": {
      "type": "object",
      "title": "Terms & Privacy Consent",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "boolean",
          "title": "I have read and accept the terms and privacy policy"
        },
        "given_at": {
          "type": "string",
          "format": "date-time"
        },
        "valid_till": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
