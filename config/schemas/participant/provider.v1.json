{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.bluedots.org/participant/provider.v1.json",
  "title": "Job Posting 1.0",
  "description": "Employers and recruiters posting jobs. Field names match the signalstack job_posting_1.0 item_state schema so submissions can flow through without re-shaping.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jobProviderName",
    "role",
    "natureOfJob",
    "hiringManagerName",
    "hiringManagerPhoneNumber",
    "jobProviderLocation"
  ],
  "properties": {
    "jobProviderName": {
      "type": "string",
      "title": "Company Name",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "title": "Role",
      "minLength": 1
    },
    "positions": {
      "type": "integer",
      "title": "Open Positions",
      "minimum": 1,
      "default": 1
    },
    "natureOfJob": {
      "type": "string",
      "title": "Nature of Job",
      "enum": ["Full-time", "Part-time", "Contract", "Internship"]
    },
    "taskRateMin": {
      "type": "integer",
      "title": "Min Rate (₹)",
      "minimum": 0
    },
    "taskRateMax": {
      "type": "integer",
      "title": "Max Rate (₹)",
      "minimum": 0
    },
    "hiringManagerName": {
      "type": "string",
      "title": "Hiring Manager Name",
      "minLength": 1
    },
    "hiringManagerEmail": {
      "type": "string",
      "title": "Hiring Manager Email",
      "format": "email"
    },
    "hiringManagerPhoneNumber": {
      "type": "string",
      "title": "Hiring Manager Mobile Number",
      "description": "E.164 format, e.g. +919876543210",
      "minLength": 8
    },
    "jobProviderLocation": {
      "type": "string",
      "title": "Job Location",
      "minLength": 1
    }
  }
}
