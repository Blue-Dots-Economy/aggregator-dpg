# Sienna ladder from brand.json.colours.primary — Sienna 500 primary,
# Sienna 700 dark, Sienna 400 mid; Pale Sienna + Cream tints for the
# 100/50 cells. Matches the OneTAC burnt-sienna wordmark.
BRAND_PRIMARY_COLOR=#9c5b1f
BRAND_PRIMARY_DARK=#7a4517
