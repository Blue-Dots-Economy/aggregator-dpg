# Brand strings for the Keycloak login page + realm displayName.
# Loaded by docker-compose via `env_file: ./config/${AGGREGATOR_NETWORK}/keycloak.env`.
# Switching networks = change `AGGREGATOR_NETWORK` in .env; this file
# travels with the network config beneath it.
BRAND_SHORT_NAME=Blue Dots
BRAND_LONG_NAME=Blue Dots Aggregator Portal
BRAND_SSO_LABEL=SSO
HERO_TITLE_LEAD=Connecting
HERO_TITLE_HIGHLIGHT=opportunity seekers
HERO_TITLE_TAIL=with the right doors.
HERO_SUBTITLE=A unified network where aggregators, providers, and seekers move together — every blue dot is a person, an opportunity, a path forward.
