# Copy this file to .env and edit values for your local stack.
# .env is git-ignored.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=aggregator
POSTGRES_PASSWORD=aggregator-dev
POSTGRES_DB=aggregator

# ── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Keycloak ────────────────────────────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_SECRET=change-me

# OTP plugin SMS provider — one of: log | twilio | sns
# 'log' writes the OTP to keycloak logs (good for local dev — no real SMS sent).
KC_SPI_SMS_PROVIDER=log

# Twilio (only used when KC_SPI_SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SNS (only used when KC_SPI_SMS_PROVIDER=sns)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMTP (for Email OTP delivery — leave blank to disable email channel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=srivatsa.k@sahamati.org.in
SMTP_USER=srivatsa.k@sahamati.org.in
SMTP_PASSWORD=jwvo kkzc lvis ysbu

# ── App (web/api) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
LOG_LEVEL=info
