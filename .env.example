# ╔══════════════════════════════════════════════════════════════════╗
# ║  AGGREGATOR-DPG — root .env (docker-compose, full stack)           ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Single sectioned env for the docker-compose stack (api, web, worker,
# postgres, redis, keycloak, minio, nginx). For the hybrid dev flow
# (services run outside docker), use the per-app apps/*/.env.example.
#
# Quick start (local):
#   cp .env.example .env
#   # fill in the REQUIRED secrets below (see `openssl` hints)
#   docker compose up -d --build
#   open http://localhost
#
# Security:
#   • This file is a TEMPLATE — it ships placeholders, never real secrets.
#   • Never commit a populated .env. Generate fresh secrets per environment.
#   • The dev defaults here are safe for a laptop ONLY — unsafe on any
#     internet-reachable host.
#
# Derived in docker-compose.yml (do NOT set them here — they're built from
# the primitives below and would be ignored/overridden):
#   DATABASE_URL, KEYCLOAK_URL, OIDC_ISSUER, CORS_ORIGINS, PUBLIC_API_URL,
#   PUBLIC_PORTAL_URL, NEXT_PUBLIC_API_URL, SCHEMA_ROOT_DIR,
#   SIGNALSTACK_ITEM_NETWORK.


# ╔══════════════════════════════════════════════════════════════════╗
# ║  1. PER-DEPLOY — review/update on every deployment                 ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Network ──────────────────────────────────────────────────────────
# The network id this instance serves. Drives SCHEMA_ROOT_DIR, the web
# config path, and SIGNALSTACK_ITEM_NETWORK (all derived in compose).
AGGREGATOR_NETWORK=blue_dot

# ── Public origin ────────────────────────────────────────────────────
# For local dev keep http/localhost. For a VM, set PUBLIC_HOST to a real
# FQDN with a public DNS A record resolving to this host BEFORE
# `docker compose up` (Let's Encrypt HTTP-01 needs it reachable on :80).
PUBLIC_PROTOCOL=http
PUBLIC_HOST=localhost                   # REQUIRED — FQDN in prod (e.g. portal.example.com)

# ── TLS / Let's Encrypt (jonasal/nginx-certbot) ──────────────────────
# CERTBOT_EMAIL must be a real, reachable mailbox — Let's Encrypt rejects
# @example.com and other placeholder TLDs, so issuance fails until it's
# an address you own. (Required by the nginx service even in local dev.)
CERTBOT_EMAIL=ops@your-domain.example   # REQUIRED — real mailbox before `docker compose up`
USE_LOCAL_CA=1                          # 1 = self-signed via pebble (local); 0 = real Let's Encrypt (prod)

# ── Runtime toggles ──────────────────────────────────────────────────
LOG_LEVEL=info                          # fatal | error | warn | info | debug | trace | silent
COOKIE_SECURE=false                     # MUST be true when PUBLIC_PROTOCOL=https; false only for plain-HTTP dev
NODE_TLS_REJECT_UNAUTHORIZED=0          # 0 tolerates the self-signed local CA; REMOVE (or set 1) in prod

# ── Admin / ops contacts ─────────────────────────────────────────────
# Comma-separated. Aggregator registration-approval emails land here.
ADMIN_EMAILS=admin@example.com


# ╔══════════════════════════════════════════════════════════════════╗
# ║  2. SECRETS — generate fresh per environment                       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-postgres-password   # REQUIRED

# ── Keycloak bootstrap admin ─────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-keycloak-admin   # REQUIRED

# ── API: registration-approval token signing key ────────────────────
APPROVAL_TOKEN_SECRET=                  # REQUIRED, ≥32 chars  →  openssl rand -hex 32

# ── Web (portal BFF): OIDC handshake / session cookie key ────────────
SESSION_KEY=                            # REQUIRED, ≥32 chars  →  openssl rand -hex 32

# ── Keycloak client secrets (confidential clients) ───────────────────
# These match the committed realm JSON (infra/keycloak/realms/*.json).
# Keep the dev defaults for local; rotate + re-import the realm for prod.
KEYCLOAK_ADMIN_CLIENT_SECRET=aggregator-api-dev-secret-change-me
OIDC_CLIENT_SECRET=aggregator-portal-dev-secret-change-me
# BFF anonymous-proxy service token. Defaults to KEYCLOAK_ADMIN_CLIENT_{ID,SECRET}
# when blank.
BFF_SERVICE_CLIENT_ID=
BFF_SERVICE_CLIENT_SECRET=


# ╔══════════════════════════════════════════════════════════════════╗
# ║  3. SMS — Keycloak OTP delivery                                    ║
# ╚══════════════════════════════════════════════════════════════════╝
# `log` writes the OTP to the keycloak container logs (dev). Switch to a
# real provider and fill its credentials for staging/prod.
KC_SPI_SMS_PROVIDER=log                 # log | twilio | sns | msg91
AWS_REGION=ap-south-1

# Twilio (KC_SPI_SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SNS (KC_SPI_SMS_PROVIDER=sns) — or use the VM's IAM role instead of keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MSG91 (KC_SPI_SMS_PROVIDER=msg91) — India, DLT-compliant Flow API
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=                      # DLT-approved Flow template id
MSG91_SENDER_ID=                        # optional; else taken from the template
MSG91_OTP_VAR_NAME=var                  # template variable that receives the OTP


# ╔══════════════════════════════════════════════════════════════════╗
# ║  4. Mail / SMTP — shared by api + keycloak                         ║
# ╚══════════════════════════════════════════════════════════════════╝
# Defaults target the in-stack Mailpit — login OTP + approval emails land
# in its web UI with no extra config. Override for a real relay (SES /
# SendGrid / Workspace SMTP). Keycloak realm SMTP is rendered from these,
# so changes apply on the next realm import (fresh DB).
MAIL_PROVIDER=smtp                      # smtp | ses
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=no-reply@bluedots.local
SMTP_FROM_DISPLAY=Blue Dots Aggregator
SMTP_AUTH=false                         # true for a real relay
SMTP_STARTTLS=false                     # true for STARTTLS relays (port 587)
SMTP_SSL=false                          # true for implicit TLS (port 465)
SMTP_SECURE=false                       # api-side flag; mirrors SMTP_SSL
SMTP_USER=
SMTP_PASSWORD=
# SES (MAIL_PROVIDER=ses)
SES_FROM=
SES_CONFIGURATION_SET=


# ╔══════════════════════════════════════════════════════════════════╗
# ║  5. Object storage — bulk uploads + error reports                  ║
# ╚══════════════════════════════════════════════════════════════════╝
# Dev: the in-stack MinIO. Prod: real S3 — leave the endpoints + keys
# blank and grant the host's IAM role s3:{Get,Put,Head,Delete}Object on
# the bucket and s3:ListBucket on the bucket itself.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_REGION=ap-south-1
S3_BUCKET=aggregator-bulk-uploads
S3_FORCE_PATH_STYLE=true                # true for MinIO; false for AWS S3
S3_ENDPOINT=http://minio:9000           # in-cluster endpoint; blank for AWS S3
S3_PUBLIC_ENDPOINT=http://localhost:9000 # browser-reachable endpoint for presigned URLs; blank → falls back to S3_ENDPOINT
S3_ACCESS_KEY_ID=minioadmin             # match MINIO_ROOT_USER for dev; blank for AWS IAM-role
S3_SECRET_ACCESS_KEY=change-me-minio-password  # match MINIO_ROOT_PASSWORD for dev; blank for AWS IAM-role


# ╔══════════════════════════════════════════════════════════════════╗
# ║  6. SignalStack outbound push                                      ║
# ╚══════════════════════════════════════════════════════════════════╝
# Leave SIGNALSTACK_BASE_URL blank to DISABLE outbound onboarding push.
# When set, ADMIN_KEY + ACTING_ORG_ID are required: on aggregator
# approval the flow registers the aggregator as a SignalStack org via
# admin api-key, acting as the platform org (sent as x-acting-org-id).
SIGNALSTACK_BASE_URL=                   # e.g. http://host.docker.internal:2347
SIGNALSTACK_ADMIN_KEY=                  # required when BASE_URL is set
SIGNALSTACK_ACTING_ORG_ID=              # platform org id, required when BASE_URL is set
SIGNALSTACK_TIMEOUT_MS=10000


# ╔══════════════════════════════════════════════════════════════════╗
# ║  7. STATIC — internal defaults, rarely changed                     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=aggregator
POSTGRES_DB=aggregator

# ── Redis (internal docker network; no secret) ───────────────────────
REDIS_URL=redis://redis:6379

# ── Keycloak ─────────────────────────────────────────────────────────
KEYCLOAK_REALM=aggregator
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_CLIENT_ID=aggregator-api # matches the committed realm JSON — do not change

# ── Web (portal BFF) ─────────────────────────────────────────────────
API_BASE_URL=http://api:4000            # docker-network DNS; not browser-visible
OIDC_CLIENT_ID=aggregator-portal        # matches the committed realm JSON — do not change
OIDC_SCOPE=openid profile email
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=43200

# ── API: bulk-upload + QR presigned URL TTLs (seconds) / size cap ────
BULK_UPLOAD_URL_TTL_SECONDS=900
BULK_UPLOAD_MAX_BYTES=10485760
QR_DOWNLOAD_URL_TTL_SECONDS=900
# Base URL embedded in registration-link QR codes; blank → ${PUBLIC_PROTOCOL}://${PUBLIC_HOST}
PUBLIC_LINK_BASE_URL=

# ── Worker (BullMQ consumer + cron) ──────────────────────────────────
BULK_MAX_ROWS=10000
BULK_MAX_ROW_BYTES=65536
LINK_METRICS_ROLLUP_INTERVAL_MS=300000  # link-metrics rollup tick (ms)
WATCHDOG_INTERVAL_MS=3600000            # stuck-job watchdog tick (ms)
