# ─── Aggregator API — local-dev environment template ────────────────────────
# Copy to apps/api/.env and edit values. Loaded automatically by `pnpm dev`
# (tsx --env-file=.env) and by `pnpm db:migrate`.
#
# Defaults below are a COMPLETE, working set for aggregator-dpg's OWN standalone
# dev compose (Postgres on host :5433, MinIO/Redis/Keycloak/Mailpit on their
# usual localhost ports). Copy, set the few "CHANGE ME" values, and you're done.
#
# Running the unified full-ecosystem stack instead (both DPGs together under
# `local-setup/`)? Only a handful of values differ — see
# local-setup/LOCAL_SETUP.md §6, Step 3.

# ── Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# ── Public URLs (admin/welcome emails + QR registration links)
PUBLIC_API_URL=http://localhost:4000
PUBLIC_PORTAL_URL=http://localhost:3000
PUBLIC_LINK_BASE_URL=http://localhost:3000

# ── Postgres (standalone compose maps host 5433 → container 5432)
DATABASE_URL=postgres://aggregator:aggregator-dev@localhost:5433/aggregator
RUN_MIGRATIONS_ON_BOOT=true

# ── Redis (BullMQ queues)
REDIS_URL=redis://localhost:6379

# ── Keycloak admin (service-account client)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aggregator
KEYCLOAK_ADMIN_CLIENT_ID=aggregator-api
KEYCLOAK_ADMIN_CLIENT_SECRET=aggregator-api-local-dev-secret

# ── Approval token (HS256). CHANGE ME — must be ≥32 chars. Generate with:
#    openssl rand -hex 32
APPROVAL_TOKEN_SECRET=replace-with-openssl-rand-hex-32-output-at-least-32-chars

# ── Admin recipients for review emails (comma-separated). CHANGE ME.
ADMIN_EMAILS=

# ── Mailer — local dev catches all mail in Mailpit (http://localhost:8025).
# For real email, point SMTP_HOST/PORT at your provider and fill user/password.
MAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@bluedots.local
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false


# Recipient for the in-app "Contact support" form. When unset, the form is
# hidden and POST /v1/support returns 503. Sent via the mailer (MAIL_PROVIDER),
# Reply-To = the submitting coordinator. Local mail lands in Mailpit (:8025).
# SUPPORT_EMAIL and SUPPORT_CC_EMAIL each accept multiple comma-separated
# addresses (e.g. hello@bluedotseconomy.org).
SUPPORT_EMAIL=
# Optional CC recipient(s) for the "Contact support" form. Comma-separated
# (e.g. vineela@ekstepplus.org). Leave blank to add no CC.
SUPPORT_CC_EMAIL=

# Support/grievance email rendered into consent copy in place of the
# __SUPPORT_EMAIL__ placeholder the config/**/consent.json files ship. Distinct
# from SUPPORT_EMAIL above (the contact-form recipient). Optional; defaults to
# hello@bluedotseconomy.org when unset.
CONSENT_SUPPORT_EMAIL=

# ── Object storage (bulk uploads + errors.csv). Dev = MinIO on localhost:9000.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aggregator-bulk-uploads
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Config-as-code (network-scoped). Paths are relative to the app dir
# (apps/api) — that's the CWD when you run `pnpm --filter @aggregator-dpg/api
# dev`, so `../../config` reaches the repo-root config/. (In Docker these are
# overridden to the absolute /app/config path.)
SCHEMA_ROOT_DIR=../../config/blue_dot/schemas
AGGREGATOR_CONFIG_PATH=../../config/blue_dot/aggregator.config.yaml

# ── SignalStack outward push (aggregator → signals-dpg).
# Leave SIGNALSTACK_BASE_URL blank to run standalone (push disabled). To enable,
# set the base URL AND fill the admin key + acting-org id from the signals-dpg
# service seed (db:seed:services). See local-setup/LOCAL_SETUP.md §4 / §6.
SIGNALSTACK_BASE_URL=
SIGNALSTACK_ADMIN_KEY=
SIGNALSTACK_ACTING_ORG_ID=
SIGNALSTACK_ITEM_NETWORK=blue_dot
