# ─── Aggregator Worker (BullMQ) — local-dev environment template ────────────
# Copy to apps/worker/.env and edit values. Loaded by `pnpm dev`
# (tsx --env-file=.env).
#
# Defaults are a COMPLETE, working set for aggregator-dpg's OWN standalone dev
# compose (Postgres on host :5433). Running the unified local-setup stack
# instead? See local-setup/LOCAL_SETUP.md §6, Step 3 for the few values that
# differ (Postgres :5432/dpg + SignalStack wiring).

# ── Server
NODE_ENV=development
LOG_LEVEL=info

# ── Postgres (standalone compose maps host 5433 → container 5432)
DATABASE_URL=postgres://aggregator:aggregator-dev@localhost:5433/aggregator

# ── Redis (BullMQ queues + scheduler)
REDIS_URL=redis://localhost:6379

# ── Object storage (bulk uploads + errors.csv). Dev = MinIO on localhost:9000.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aggregator-bulk-uploads
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Config-as-code (network-scoped). Paths are relative to the app dir
# (apps/worker) — the CWD when you run `pnpm --filter @aggregator-dpg/worker
# dev` — so `../../config` reaches the repo-root config/. (Docker overrides to
# the absolute /app/config path.)
SCHEMA_ROOT_DIR=../../config/blue_dot/schemas
AGGREGATOR_CONFIG_PATH=../../config/blue_dot/aggregator.config.yaml

# ── SignalStack outward push (participant onboarding → signals-dpg).
# Leave SIGNALSTACK_BASE_URL blank to run standalone (push disabled). To enable,
# set the base URL AND the admin key from the signals-dpg service seed
# (db:seed:services). The worker onboards participants, so — unlike the API — it
# needs no acting-org id (the org is derived per row).
SIGNALSTACK_BASE_URL=
SIGNALSTACK_ADMIN_KEY=
SIGNALSTACK_ITEM_NETWORK=blue_dot

# ── Optional tuning (sensible defaults applied when unset) ───────────────────
# WORKER_ROLES: comma-separated subset of file,row,finalise,cron (default: all).
# WORKER_ROLES=all
# BULK_MAX_ROWS=10000
# BULK_MAX_ROW_BYTES=65536
# LINK_METRICS_ROLLUP_INTERVAL_MS=60000
# WATCHDOG_INTERVAL_MS=3600000
