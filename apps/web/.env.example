# ─── Aggregator Web (Next.js BFF) — local-dev environment template ──────────
# Copy to apps/web/.env and edit values. Next.js auto-loads `.env` from this
# directory in dev mode.
#
# Defaults below are a COMPLETE, working set for local dev (standalone or the
# unified local-setup stack). Copy, set the "CHANGE ME" values, and you're done.
# Running the unified stack? See local-setup/LOCAL_SETUP.md §6, Step 3 for the
# one or two values that differ (OIDC_ISSUER host).

# ── OIDC (Keycloak). Portal is a CONFIDENTIAL client, so the secret is required.
OIDC_ISSUER=http://localhost:8080/realms/aggregator
OIDC_CLIENT_ID=aggregator-portal
OIDC_CLIENT_SECRET=aggregator-portal-dev-secret-change-me
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
OIDC_SCOPE=openid profile email
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login

# ── Session (signed cookie + store)
# CHANGE ME — 32+ char random string that HMAC-signs the OIDC flow cookie +
# session id. Generate with: openssl rand -hex 32
SESSION_KEY=replace-with-openssl-rand-hex-32-output-at-least-32-chars
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=43200
# Portal is served over plain HTTP locally, so cookies must NOT be Secure.
COOKIE_SECURE=false

# ── Redis (session store). Falls back to in-memory store if unset.
REDIS_URL=redis://localhost:6379

# ── Upstream API (used by BFF callApi + register proxy)
API_BASE_URL=http://localhost:4000
# Public origin of this portal; used in a few server-rendered links.
PUBLIC_PORTAL_URL=http://localhost:3000

# ── Service-account client (BFF calls the backend for anonymous browsers, e.g.
#     registration). Reuses the `aggregator-api` confidential client — same
#     secret as KEYCLOAK_ADMIN_CLIENT_SECRET in apps/api/.env.
BFF_SERVICE_CLIENT_ID=aggregator-api
BFF_SERVICE_CLIENT_SECRET=aggregator-api-dev-secret-change-me

# ── Config-as-code (network-scoped). Path is relative to the app dir (apps/web)
# — the CWD when you run `pnpm --filter @aggregator-dpg/web dev` — so
# `../../config` reaches the repo-root config/. (Docker overrides to /app/config.)
SCHEMA_ROOT_DIR=../../config/blue_dot/schemas

# ── i18n (UI localization) ──
# Comma-separated UI languages shown in the switcher, in display order.
# Codes must match files in src/i18n/messages/<code>.json. `en` is always
# included. Unset → all available languages are shown. Baked at build time
# (NEXT_PUBLIC_*), so a VM rebuild is needed to change it.
NEXT_PUBLIC_ENABLED_LANGUAGES=en,kn,hi
