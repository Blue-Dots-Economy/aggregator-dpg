# ─── Aggregator Web (Next.js BFF) — local-dev environment template ──────────
# Copy to apps/web/.env and edit values. Next.js auto-loads `.env` from this
# directory in dev mode.

# ── OIDC (Keycloak)
OIDC_ISSUER=http://localhost:8080/realms/aggregator
OIDC_CLIENT_ID=aggregator-portal
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
OIDC_SCOPE=openid profile email
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login

# ── Session (signed cookie + store)
# 32+ char random string used to HMAC-sign the OIDC flow cookie + session id.
# Generate with: openssl rand -hex 32
SESSION_KEY=replace-with-openssl-rand-hex-32-output-at-least-32-chars
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=43200

# ── Redis (session store). Falls back to in-memory store if unset.
REDIS_URL=redis://localhost:6379

# ── Upstream API (used by BFF callApi + register proxy)
API_BASE_URL=http://localhost:4000

# ── Service-account client (used by BFF to call backend on behalf of
#     anonymous browsers, e.g. registration). Reuses the existing
#     `aggregator-api` confidential client — same secret as
#     KEYCLOAK_ADMIN_CLIENT_SECRET in apps/api/.env.
BFF_SERVICE_CLIENT_ID=aggregator-api
BFF_SERVICE_CLIENT_SECRET=replace-with-aggregator-api-secret

# ── i18n (UI localization) ──
# Comma-separated UI languages shown in the switcher, in display order.
# Codes must match files in src/i18n/messages/<code>.json. `en` is always
# included. Unset → all available languages are shown. Baked at build time
# (NEXT_PUBLIC_*), so a VM rebuild is needed to change it.
NEXT_PUBLIC_ENABLED_LANGUAGES=en,kn,hi
