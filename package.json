{
  "name": "aggregator-dpg",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "prepare": "husky",
    "new-service": "tsx scripts/new-service.ts",
    "dep-check": "depcruise packages --config .dependency-cruiser.cjs --output-type err-long",
    "test:scripts": "node --test scripts/stack.test.mjs",
    "stack:setup": "node scripts/stack.mjs setup",
    "stack:up": "node scripts/stack.mjs up",
    "stack:down": "node scripts/stack.mjs down",
    "stack:reset": "node scripts/stack.mjs reset",
    "stack:logs": "node scripts/stack.mjs logs",
    "stack:ps": "node scripts/stack.mjs ps",
    "stack:psql": "node scripts/stack.mjs psql",
    "stack:rebuild-web": "node scripts/stack.mjs rebuild-web"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,yaml,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.4",
    "turbo": "^2.9.14",
    "typescript-eslint": "^8.59.0"
  }
}
