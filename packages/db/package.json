{
  "name": "@aggregator-dpg/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./interface": {
      "import": "./dist/interface.js",
      "types": "./dist/interface.d.ts"
    },
    "./postgres": {
      "import": "./dist/postgres/index.js",
      "types": "./dist/postgres/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.schema.js",
      "types": "./dist/config.schema.d.ts"
    },
    "./repositories": {
      "import": "./dist/repositories/index.js",
      "types": "./dist/repositories/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate:generate": "drizzle-kit generate",
    "migrate:up": "drizzle-kit migrate",
    "migrate:status": "drizzle-kit status"
  },
  "dependencies": {
    "@aggregator-dpg/shared-primitives": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@aggregator-dpg/tsconfig": "workspace:*",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.2.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
  }
}
