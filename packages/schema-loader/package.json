{
  "name": "@aggregator-dpg/schema-loader",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./interface": {
      "import": "./dist/interface.js",
      "types": "./dist/interface.d.ts"
    },
    "./file": {
      "import": "./dist/file-loader.js",
      "types": "./dist/file-loader.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aggregator-dpg/shared-primitives": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@aggregator-dpg/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
