# ═══════════════════════════════════════════════════════════════════════════
# Signals-dots — unified LOCAL docker-compose environment
#
#   cp .env.example .env
#   # edit ADMIN_EMAILS (below); the pre-filled dev secrets work as-is locally
#   docker compose up -d
#
# ⚠️  These are DEV-ONLY secrets, safe only on localhost. NEVER reuse them on a
#     shared host, staging, or production. Regenerate real ones with:
#         openssl rand -hex 32        (SESSION_KEY, APPROVAL_TOKEN_SECRET)
#         openssl rand -base64 32     (SIGNALS_PII_KEY — must decode to 32 bytes)
# ═══════════════════════════════════════════════════════════════════════════

# ─── Shared Postgres (hosts the aggregator, signals, and keycloak databases) ──
POSTGRES_USER=dpg
POSTGRES_PASSWORD=e836a08f62b0cd903e622ee72db80b8e
AGGREGATOR_DB=aggregator

# ─── Redis ────────────────────────────────────────────────────────────────
# signals-dpg requires a Redis password; aggregator-dpg uses its own instance.
SIGNALS_REDIS_PASSWORD=15ccbee2c08954f0b170a97fa2e6404b

# ─── Keycloak (aggregator identity) ─────────────────────────────────────────
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=e47b44b8a1f91a8a843fd4c3
KEYCLOAK_REALM=aggregator
# Substituted into the realm by render-realm.sh at container boot (no longer committed in the realm JSON).
OIDC_PORTAL_CLIENT_SECRET=aggregator-portal-local-dev-secret
OIDC_API_CLIENT_SECRET=aggregator-api-local-dev-secret
OIDC_BFF_CLIENT_SECRET=aggregator-bff-local-dev-secret

# ─── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=aggregator-bulk-uploads
S3_REGION=us-east-1

# ─── Email ───────────────────────────────────────────────────────────────
# All mail is captured by Mailpit (http://localhost:8025) locally — no real
# SMTP account needed. SMTP_FROM is just the visible "From" address.
SMTP_FROM=no-reply@bluedots.local
SMTP_FROM_DISPLAY=Blue Dots Aggregator

# ─── Aggregator app ─────────────────────────────────────────────────────────
AGGREGATOR_NETWORK=blue_dot
LOG_LEVEL=info
NEXT_PUBLIC_ENABLED_LANGUAGES=en,kn,hi
# ⚠️  REQUIRED EDIT: your real email. New-aggregator approval mails land here
#     (open them in Mailpit at http://localhost:8025). Comma-separated for many.
ADMIN_EMAILS=your-admin-email@example.com
# App secrets (>=32 chars each). Pre-filled dev values below.
SESSION_KEY=8ffbd2cf7c072530e62e7b7cbf8149d0e8224003903ad26584295c8b29b02a0d
APPROVAL_TOKEN_SECRET=cef506ca7e934ad075ef9ccfb2b78e22ae20aac707eaab58572a079d1081acb4

# ─── Signals app ────────────────────────────────────────────────────────────
SIGNALS_SERVED_DOMAINS=blue_dot/seeker,blue_dot/provider
SIGNALS_AUTH_SECRET=66b47ab9af80ef0eea969fda7dee28977d9d03ed2ec1e434
# base64-encoded 32-byte AES-256 key (PII field encryption).
SIGNALS_PII_KEY=uzfG/SKRFkLbM8l53UW5sLRTxPv9hIdj4qoIBibb1Vc=

# ─── Cross-DPG wiring (optional — fill AFTER the first `up`) ──────────────────
# Leave blank on first boot. The `signals-bootstrap` container mints an apikey
# for aggregator-dpg and prints it (with the acting-org id) to its logs:
#     docker compose logs signals-bootstrap
# Paste them here, then: docker compose up -d aggregator-api aggregator-worker
# See LOCAL_SETUP.md §"Wire aggregator-dpg -> signals-dpg".
SIGNALSTACK_BASE_URL=http://signals-api:2742
SIGNALSTACK_ADMIN_KEY=
SIGNALSTACK_ACTING_ORG_ID=
