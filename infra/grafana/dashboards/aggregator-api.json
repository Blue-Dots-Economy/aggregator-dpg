{
  "title": "Aggregator API",
  "uid": "aggregator-api",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["aggregator"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (5m)",
      "targets": [
        {
          "expr": "sum by (route, method) (rate(aggregator_api_requests_total[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(aggregator_api_request_duration_ms_bucket[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx rate",
      "targets": [
        {
          "expr": "sum (rate(aggregator_api_5xx_total[5m]))",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    }
  ]
}
