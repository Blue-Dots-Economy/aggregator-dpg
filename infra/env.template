# ╔══════════════════════════════════════════════════════════╗
# ║ 1. DYNAMIC — review/update every deploy                  ║
# ╚══════════════════════════════════════════════════════════╝

# Public-facing origin. Must be a real FQDN with a public DNS A record
# pointing to this VM BEFORE `docker compose up` — Let's Encrypt HTTP-01
# challenge needs the domain to resolve and inbound :80 to be reachable.
# For pure local dev keep PUBLIC_PROTOCOL=http and PUBLIC_HOST=localhost
# (skip CERTBOT_EMAIL/USE_LOCAL_CA — the nginx service won't start without
# them, so swap to nginx:alpine for offline local work).
PUBLIC_PROTOCOL=https
PUBLIC_HOST=portal.example.com          # public FQDN — update for this VM

# ── TLS / Let's Encrypt (consumed by jonasal/nginx-certbot) ─
# Cert expiry + abuse notifications. Must be a reachable mailbox on a real
# domain — Let's Encrypt rejects @example.com and other placeholder TLDs,
# so cert issuance fails until this is set to an address you actually own.
CERTBOT_EMAIL=ops@your-domain.example          # set to a real mailbox before `docker compose up`
# 1 = self-signed via pebble (smoke-test without LE rate limits)
# 0 = real Let's Encrypt certificates (production)
USE_LOCAL_CA=0

# ── runtime toggles ─────────────────────────────────────────
LOG_LEVEL=info
COOKIE_SECURE=true                      # required when PUBLIC_PROTOCOL=https; `false` only for plain-HTTP dev

# ── admin / ops contacts ────────────────────────────────────
ADMIN_EMAILS=admin@example.com

# ── postgres secrets ────────────────────────────────────────
POSTGRES_PASSWORD=aggregator-dev

# ── object storage (AWS S3, IAM role) ───────────────────────
# No access keys here — the VM's EC2 instance role must grant:
#   s3:GetObject, s3:PutObject, s3:HeadObject, s3:DeleteObject on
#   arn:aws:s3:::${S3_BUCKET}/* and s3:ListBucket on the bucket itself.
# Create the bucket once with:  aws s3 mb s3://${S3_BUCKET} --region ${S3_REGION}
S3_REGION=ap-south-1
S3_BUCKET=aggregator-bulk-uploads
# false → virtual-hosted-style URLs (AWS S3 default). Keep true only when
# pointing at a path-style endpoint (e.g. a self-hosted MinIO for local dev).
S3_FORCE_PATH_STYLE=false

# ── keycloak secrets ────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-keycloak-admin-password

# ── SMS provider (twilio / aws sns) ─────────────────────────
KC_SPI_SMS_PROVIDER=log                 # `log` (dev) | `twilio` | `sns`
AWS_REGION=ap-south-1
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── mail / smtp (shared by api + keycloak) ──────────────────
# Defaults target the in-stack MailHog — login OTP emails land in
# https://${PUBLIC_HOST}/mail/ on first boot with no extra config. To send
# real email (SES/SendGrid/Workspace SMTP), override these in this file.
# Keycloak's realm.smtpServer is rendered from these by render-realm.sh,
# so changing them takes effect on the next realm import (fresh DB) — for
# an existing realm, also patch via kcadm or the Admin Console UI.
MAIL_PROVIDER=smtp                      # `smtp` | `ses`
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@bluedots.local
SMTP_FROM_DISPLAY=Blue Dots Aggregator
SMTP_AUTH=false                         # set true when using a real SMTP relay
SMTP_STARTTLS=false                     # MailHog has no TLS; flip true for STARTTLS relays (port 587)
SMTP_SSL=false                          # flip true for implicit TLS (port 465)
SMTP_SECURE=false                       # api-side flag; matches SMTP_SSL semantics
SMTP_USER=
SMTP_PASSWORD=
SES_FROM=
SES_CONFIGURATION_SET=

# ── api secrets ─────────────────────────────────────────────
KEYCLOAK_ADMIN_CLIENT_SECRET=aggregator-api-dev-secret-change-me
APPROVAL_TOKEN_SECRET=                  # openssl rand -hex 32   (≥32 chars, REQUIRED)

# ── web (portal BFF) secrets ────────────────────────────────
OIDC_CLIENT_SECRET=change-me-keycloak-portal-client-secret
SESSION_KEY=                            # openssl rand -hex 32   (≥32 chars, REQUIRED)
# BFF anonymous-proxy service token (used for routes that hit the API on
# behalf of unauthenticated browsers, e.g. POST /api/aggregator/register).
# Defaults to KEYCLOAK_ADMIN_CLIENT_ID/SECRET above if unset.
BFF_SERVICE_CLIENT_ID=
BFF_SERVICE_CLIENT_SECRET=


# ╔══════════════════════════════════════════════════════════╗
# ║ 2. STATIC — internal defaults; rarely touched            ║
# ╚══════════════════════════════════════════════════════════╝

# ── postgres ────────────────────────────────────────────────
POSTGRES_USER=aggregator
POSTGRES_DB=aggregator

# ── redis (internal docker network only; no secret) ─────────
REDIS_URL=redis://redis:6379

# ── keycloak ────────────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_USERNAME=admin

# ── api ─────────────────────────────────────────────────────
KEYCLOAK_REALM=aggregator
KEYCLOAK_ADMIN_CLIENT_ID=aggregator-api
# Bulk-upload + QR presigned URL TTLs (seconds) and size cap (bytes).
BULK_UPLOAD_URL_TTL_SECONDS=900
BULK_UPLOAD_MAX_BYTES=10485760
QR_DOWNLOAD_URL_TTL_SECONDS=900
# Base URL embedded in registration-link QR codes shown to participants.
# Defaults to ${PUBLIC_PROTOCOL}://${PUBLIC_HOST} when unset.
PUBLIC_LINK_BASE_URL=

# ── worker (BullMQ consumer + cron) ────────────────────────
BULK_MAX_ROWS=10000
BULK_MAX_ROW_BYTES=65536
LINK_METRICS_ROLLUP_INTERVAL_MS=300000
WATCHDOG_INTERVAL_MS=3600000

# ── web (portal BFF) ────────────────────────────────────────
API_BASE_URL=http://api:4000            # docker-network DNS; not browser-visible
OIDC_CLIENT_ID=aggregator-portal
OIDC_SCOPE=openid profile email
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=43200
