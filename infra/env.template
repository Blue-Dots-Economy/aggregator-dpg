# ════════════════════════════════════════════════════════════
# AGGREGATOR-DPG — environment template
#
# Usage:
#   cp infra/env.template .env
#   # populate every "change-me-*" placeholder and blank secret
#   chmod 600 .env
#   docker compose up -d --build
#
# Conventions:
#   - One file per environment (.env, .env.staging, .env.prod)
#   - Each service has a config block (non-sensitive) and a secrets block
#   - Secrets blank in template; never commit real values
#   - Generate strong secrets: `openssl rand -hex 32`
#   - On VM: chmod 600, owner root
#   - K8s migration: split blocks → ConfigMap (config) + Secret (secrets)
# ════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════
# postgres
# ════════════════════════════════════════════════════════════
# --- config ---
POSTGRES_USER=aggregator
POSTGRES_DB=aggregator
# --- secrets ---
POSTGRES_PASSWORD=change-me-postgres-password


# ════════════════════════════════════════════════════════════
# redis
# ════════════════════════════════════════════════════════════
# --- config ---
REDIS_URL=redis://redis:6379
# --- secrets ---
# (none — internal docker network only)


# ════════════════════════════════════════════════════════════
# minio
# ════════════════════════════════════════════════════════════
# --- config ---
MINIO_ROOT_USER=minioadmin
# --- secrets ---
MINIO_ROOT_PASSWORD=change-me-minio-password


# ════════════════════════════════════════════════════════════
# keycloak
# ════════════════════════════════════════════════════════════
# --- config ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_HOSTNAME=keycloak                    # must match OIDC_ISSUER hostname; add `127.0.0.1 keycloak` to /etc/hosts on host
KC_SPI_SMS_PROVIDER=log
AWS_REGION=ap-south-1
# --- secrets ---
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-keycloak-admin-password
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ════════════════════════════════════════════════════════════
# mailhog / smtp (shared by api + keycloak)
# ════════════════════════════════════════════════════════════
# --- config ---
MAIL_PROVIDER=smtp
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@bluedots.local
SMTP_SECURE=false
SES_FROM=
SES_CONFIGURATION_SET=
# --- secrets ---
SMTP_USER=
SMTP_PASSWORD=


# ════════════════════════════════════════════════════════════
# api
# ════════════════════════════════════════════════════════════
# --- config ---
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3100
RUN_MIGRATIONS_ON_BOOT=true
KEYCLOAK_REALM=aggregator
KEYCLOAK_ADMIN_CLIENT_ID=aggregator-api
ADMIN_EMAILS=admin@bluedots.local
PUBLIC_API_URL=http://localhost:4000
PUBLIC_PORTAL_URL=http://localhost:3100
# --- secrets ---
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-keycloak-api-service-secret
APPROVAL_TOKEN_SECRET=                  # openssl rand -hex 32   (≥32 chars, REQUIRED)


# ════════════════════════════════════════════════════════════
# web
# ════════════════════════════════════════════════════════════
# --- config ---
NEXT_PUBLIC_API_URL=http://localhost:4000              # build-time bake — set before `docker compose build`
API_BASE_URL=http://api:4000
OIDC_ISSUER=http://keycloak:8080/realms/aggregator     # MUST resolve identically from browser AND web container — requires `127.0.0.1 keycloak` in /etc/hosts
OIDC_CLIENT_ID=aggregator-portal
OIDC_REDIRECT_URI=http://localhost:3100/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3100/
OIDC_SCOPE=openid profile email
SESSION_COOKIE_NAME=sid
SESSION_TTL_SECONDS=43200
# Browser cookie `Secure` flag. Default `false` for HTTP deploys (incl. local
# dev and any VM reached over plain http). Switch to `true` only when serving
# the portal over HTTPS — otherwise browsers silently drop the OIDC flow
# cookie and the callback fails with `?error=invalid_flow_cookie`.
COOKIE_SECURE=false
# --- secrets ---
OIDC_CLIENT_SECRET=change-me-keycloak-portal-client-secret
SESSION_KEY=                            # openssl rand -hex 32   (≥32 chars, REQUIRED)
